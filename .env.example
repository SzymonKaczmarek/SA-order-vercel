# Skopiuj ten plik jako .env i wklej prawdziwy connection string Neon.
# cp .env.example .env
#
# env pull (vercel) tworzy .env.local, ale dla Neon wartości są puste "" —
# wrażliwe zmienne nie są zwracane przez CLI. Connection string trzymaj w .env.

DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Alternatywnie (wystarczy jedna z poniższych):
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=

# Opcjonalnie – logowanie gdy baza kont jest pusta (JSON tablica użytkowników)
# AUTH_USERS=[{"username":"admin","password":"admin123","role":"admin","firstName":"Admin","lastName":"Demo","email":"admin@example.com"}]
