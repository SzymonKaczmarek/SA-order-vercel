# Neon PostgreSQL (integracja Vercel → Storage → neon-bistre-basket)
# Skopiuj connection string z panelu Vercel lub Neon Console.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Alternatywne nazwy ustawiane przez integrację Vercel + Neon:
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=

# Opcjonalnie – logowanie gdy baza kont jest pusta (JSON tablica użytkowników)
# AUTH_USERS=[{"username":"admin","password":"admin123","role":"admin","firstName":"Admin","lastName":"Demo","email":"admin@example.com"}]
